# ── Database ──────────────────────────────────────────────────────────────────
# Matches the docker-compose.yml defaults
DATABASE_URL=postgresql://primitive:primitive@localhost:5433/primitive?sslmode=disable

# ── Auth (Clerk) ──────────────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_
CLERK_SECRET_KEY=sk_test_
# Webhook secret from Clerk dashboard → Webhooks → your endpoint
CLERK_WEBHOOK_SECRET=whsec_

# Redirect URLs configured in Clerk dashboard (Dashboard → Redirects)
# After sign-in: /dashboard  |  After sign-up: /onboarding

# Visitor session cookie for public campaign flows (NOT admin auth — that's Clerk)
CAMPAIGN_SESSION_SECRET=local-dev-campaign-secret-change-in-production
# HMAC key for unsubscribe tokens in broadcast emails
SESSION_SECRET=local-dev-session-secret-change-in-production
CRON_SECRET=local-dev-cron-secret

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Leave blank locally — emails are logged to the console instead
RESEND_API_KEY=
EMAIL_FROM=noreply@localhost

# ── Cloudflare R2 (optional locally) ─────────────────────────────────────────
# Leave blank to skip media uploads locally
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=http://localhost:3000

# ── Stripe (optional locally) ─────────────────────────────────────────────────
# Leave blank to disable billing UI locally
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_ENTERPRISE=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Upstash Redis (rate limiting) ────────────────────────────────────────────
# Optional locally (blank = rate limiting is a no-op in dev).
# REQUIRED in production: guards login brute-force and audience lookup
# enumeration. If unset when NODE_ENV=production, rate-limited endpoints FAIL
# CLOSED (deny traffic) and log a fatal error.
#
# The code accepts EITHER naming scheme — no need to set both:
#   • Direct Upstash:            UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN
#   • Vercel Upstash integration: KV_REST_API_URL / KV_REST_API_TOKEN (auto-injected)
# Use the REST URL/token — NOT the redis:// REDIS_URL connection string.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
